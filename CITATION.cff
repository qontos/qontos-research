  - family-names: Tamilselvan
    given-names: Ramesh
license: Apache-2.0
repository-code: "https://github.com/qontos/qontos-research"
url: "https://qontos.com"
version: "0.2.0"
date-released: "2026-03-23"
keywords:
  - quantum computing
  - fault tolerance
  - error correction
  - tantalum qubits
  - photonic interconnects
  - quantum software
  - modular quantum computing
